        var turnstileIds = [];

        var cf7srLoadTurnstile = function() {
            var widgets = document.querySelectorAll('.cf7sr-g-turnstile');
            for (var i = 0; i < widgets.length; ++i) {
                var widget = widgets[i];
                turnstileIds.push(
